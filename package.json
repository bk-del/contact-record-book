{
  "name": "contact-record-book",
  "version": "1.0.0",
  "description": "A desktop application for managing contact records with PDF generation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "lint": "biome lint . --files-ignore-unknown=true --diagnostic-level=error && htmlhint \"index.html\"",
    "lint:fix": "biome lint . --write --files-ignore-unknown=true --diagnostic-level=error && htmlhint \"index.html\"",
    "format": "biome format . --write --files-ignore-unknown=true",
    "format:check": "biome format . --files-ignore-unknown=true",
    "check": "npm run lint && npm run format:check && npm test",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.contactbook.app",
    "productName": "Contact Record Book",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "preload.js",
      "config.json",
      "contact-utils.js",
      "backup-utils.js",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "artifactName": "contact_book_windows.exe"
    },
    "mac": {
      "target": "dmg",
      "artifactName": "contact_book_mac.dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [
    "contacts",
    "pdf",
    "record-book"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "pdfkit": "^0.13.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "electron": "^40.0.0",
    "electron-builder": "^26.5.0",
    "htmlhint": "^1.9.2"
  }
}
